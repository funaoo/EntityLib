{
    "name": "funaoo/entitylib",
    "description": "A powerful and easy-to-use library for creating interactive NPCs and entities in PocketMine-MP 5",
    "version": "1.2.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Funaoo",
            "homepage": "https://github.com/funaoo"
        }
    ],
    "homepage": "https://github.com/funaoo/EntityLib",
    "keywords": [
        "pocketmine",
        "pmmp",
        "npc",
        "entity",
        "entitylib",
        "virion",
        "minecraft-bedrock"
    ],
    "require": {
        "php": ">=8.1",
        "pocketmine/pocketmine-mp": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Funaoo\\EntityLib\\": "src/Funaoo/EntityLib/"
        }
    },
    "minimum-stability": "stable",
